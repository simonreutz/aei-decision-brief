<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Genotwin · Board Briefing Pack · SAP SE · Q3 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#0c0e1a;--paper:#f4ecd8;--paper-2:#efe6cf;--ink:#1a1610;--ink-2:#2a2418;--soft:#6b5d3a;--line:#cabf9d;
    --gold:#9a7b2e;--gold-bright:#c9a44c;--oxblood:#7a2e2e;--moss:#5a6e3a;--burnt:#b3622a;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;--sans:'Inter',sans-serif;--mono:'JetBrains Mono',monospace;
  }
  *,*::before,*::after{box-sizing:border-box}
  body{margin:0;background:var(--bg);font-family:var(--sans);color:var(--ink-2);-webkit-font-smoothing:antialiased}
  ::selection{background:var(--gold-bright);color:var(--ink)}
  .progress{position:fixed;top:0;left:0;height:3px;background:var(--gold-bright);width:0;z-index:50;transition:width .1s}
  .toc{position:fixed;top:28px;right:28px;z-index:40;background:rgba(12,14,26,.85);backdrop-filter:blur(14px);border:1px solid #252a44;padding:14px 16px;max-width:200px}
  .toc-l{font-family:var(--mono);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:#7a8099;margin-bottom:10px}
  .toc a{display:block;font-family:var(--mono);font-size:10px;letter-spacing:.04em;color:#c8c2b1;text-decoration:none;padding:4px 0;transition:color .2s}
  .toc a:hover{color:var(--gold-bright)}
  @media(max-width:900px){.toc{display:none}}

  .doc{max-width:760px;margin:0 auto;padding:60px 24px 100px}
  .page{background:var(--paper);color:var(--ink-2);padding:64px 60px;margin-bottom:28px;position:relative;box-shadow:0 24px 60px rgba(0,0,0,.4)}
  .page::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--gold-bright),var(--oxblood))}
  .kicker{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--soft);margin-bottom:18px}
  .cover{min-height:420px;display:flex;flex-direction:column;justify-content:center}
  .cover-title{font-family:var(--serif);font-size:clamp(40px,7vw,64px);font-weight:300;color:var(--ink);letter-spacing:-.03em;line-height:1;margin:0 0 16px}
  .cover-sub{font-family:var(--serif);font-style:italic;font-size:20px;color:var(--soft);margin-bottom:40px}
  .cover-meta{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--soft);line-height:2;border-top:1px solid var(--line);padding-top:24px}
  .cover-meta b{color:var(--ink)}
  h2{font-family:var(--serif);font-size:30px;font-weight:300;color:var(--ink);letter-spacing:-.02em;margin:0 0 8px;line-height:1.1}
  .rule{height:1px;background:var(--line);margin:22px 0}
  p{font-size:15px;line-height:1.7;color:var(--ink-2)}
  .letter{font-family:var(--serif);font-size:16px;line-height:1.8;color:var(--ink-2)}
  .letter p{font-size:16px;line-height:1.8;margin:0 0 18px}
  .sign{margin-top:30px;font-family:var(--serif);font-style:italic;font-size:18px;color:var(--ink)}
  .sign small{display:block;font-family:var(--mono);font-style:normal;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--soft);margin-top:5px}
  .traj{display:flex;align-items:flex-end;gap:30px;margin:30px 0}
  .traj-svg{flex:1}
  .traj-now{font-family:var(--serif);font-size:48px;font-weight:300;color:var(--oxblood);line-height:1}
  .traj-now small{display:block;font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--soft);margin-top:6px}
  .decision{border:1px solid var(--line);border-left:3px solid var(--oxblood);padding:28px 30px;margin:20px 0;background:rgba(122,46,46,.04)}
  .decision-tag{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--oxblood);margin-bottom:10px}
  .decision-name{font-family:var(--serif);font-size:26px;color:var(--ink);letter-spacing:-.02em;margin-bottom:8px}
  .decision-name em{font-style:italic;color:var(--gold)}
  .dgrid{display:flex;border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin:16px 0}
  .dcell{flex:1;padding:14px 0;border-right:1px solid var(--line)}
  .dcell:last-child{border-right:none}
  .dcell-v{font-family:var(--serif);font-size:24px;color:var(--gold);font-weight:400}
  .dcell-l{font-family:var(--mono);font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--soft);margin-top:5px}
  .timeline{list-style:none;padding:0;margin:18px 0 0}
  .timeline li{display:grid;grid-template-columns:90px 1fr;gap:16px;padding:11px 0;border-bottom:1px dotted var(--line);font-size:14px;align-items:baseline}
  .timeline .date{font-family:var(--mono);font-size:11px;color:var(--soft)}
  .bs{margin:24px 0;padding-bottom:20px;border-bottom:1px solid var(--line)}
  .bs:last-child{border-bottom:none}
  .bs-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px}
  .bs-title{font-family:var(--serif);font-size:20px;color:var(--ink)}
  .bs-val{font-family:var(--mono);font-size:13px;color:var(--oxblood)}
  .bs-status{display:inline-block;font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;margin-bottom:10px}
  .st-watch{background:rgba(179,98,42,.14);color:var(--burnt)}
  .st-active{background:rgba(122,46,46,.12);color:var(--oxblood)}
  .st-improving{background:rgba(90,110,58,.14);color:var(--moss)}
  table{width:100%;border-collapse:collapse;margin-top:14px}
  th{font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--soft);text-align:left;padding:8px 10px;border-bottom:1px solid var(--line)}
  td{padding:10px;border-bottom:1px solid var(--line);font-size:14px;color:var(--ink-2)}
  td.n{font-family:var(--mono);text-align:right}
  .up{color:var(--moss)}.down{color:var(--oxblood)}
  .q{counter-reset:q;list-style:none;padding:0;margin:18px 0 0}
  .q li{counter-increment:q;padding:16px 0 16px 44px;border-bottom:1px solid var(--line);font-family:var(--serif);font-size:17px;color:var(--ink);position:relative;line-height:1.4}
  .q li::before{content:counter(q,decimal-leading-zero);position:absolute;left:0;top:16px;font-family:var(--mono);font-size:12px;color:var(--gold)}
  .record{font-family:var(--mono);font-size:12px}
  .record-row{display:grid;grid-template-columns:200px 1fr;gap:14px;padding:9px 0;border-bottom:1px dotted var(--line)}
  .record-id{color:var(--oxblood)}
  .record-d{color:var(--ink-2);font-family:var(--sans);font-size:13px}
  .audit{font-family:var(--mono);font-size:12px;line-height:2;color:var(--soft)}
  .audit b{color:var(--ink)}
  .back{display:inline-block;margin-bottom:30px;font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#7a8099;text-decoration:none;border:1px solid #252a44;padding:11px 18px;transition:all .2s}
  .back:hover{color:var(--gold-bright);border-color:var(--gold-bright)}
</style>
</head>
