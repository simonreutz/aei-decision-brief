<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>AEI · Architecture, Data Flow &amp; Decision Support</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#0c0e1a;--bg-2:#11142a;--surface:#151829;--surface-2:#1a1e34;
    --border:#252a44;--border-soft:#1d2138;
    --gold:#c9a44c;--gold-soft:#8a7333;--gold-glow:rgba(201,164,76,.18);
    --oxblood:#7a2e2e;--burnt:#c97a3a;--moss:#6b8e5a;--teal:#4a8c8c;
    --bone:#e8e3d5;--bone-2:#c8c2b1;--mute:#7a8099;--mute-2:#565b76;
    --paper:#f4ecd8;--paper-ink:#2a2418;--paper-soft:#6b5d3a;--paper-line:#c9bf9e;
    --serif:'Fraunces','Iowan Old Style',Georgia,serif;--sans:'Inter',-apple-system,sans-serif;--mono:'JetBrains Mono',ui-monospace,monospace;
  }
  *,*::before,*::after{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--bone);font-family:var(--sans);line-height:1.5;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  ::selection{background:var(--gold);color:var(--bg)}
  body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse 70% 50% at 50% -10%,rgba(201,164,76,.06),transparent 60%),radial-gradient(ellipse 60% 50% at 90% 110%,rgba(74,140,140,.05),transparent 60%)}
  .wrap{max-width:1280px;margin:0 auto;padding:0 28px;position:relative;z-index:1}

  header{padding:54px 0 30px}
  .eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);display:inline-flex;align-items:center;gap:12px;margin-bottom:20px}
  .eyebrow::before{content:'';width:28px;height:1px;background:var(--gold)}
  h1{font-family:var(--serif);font-weight:400;letter-spacing:-.02em;font-size:clamp(30px,4vw,46px);line-height:1.08;margin:0 0 18px;max-width:21ch}
  h1 em{font-style:italic;color:var(--gold);font-weight:300}
  .sub{font-family:var(--serif);font-weight:300;font-size:clamp(15px,1.5vw,18px);color:var(--bone-2);max-width:68ch;line-height:1.55}
  .sub b{color:var(--gold);font-weight:400;font-style:italic}

  .controls{display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;margin:36px 0 8px;padding-bottom:22px;border-bottom:1px solid var(--border-soft)}
  .legend{display:flex;gap:22px;flex-wrap:wrap;font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--mute)}
  .lg{display:flex;align-items:center;gap:8px}.lg .sw{width:11px;height:11px;border-radius:2px}
  .sw.tap{background:var(--gold)}.sw.crawl{background:var(--teal)}.sw.engine{background:var(--bone-2)}.sw.artifact{background:var(--burnt)}.sw.loop{background:transparent;border:1px dashed var(--oxblood)}
  .ctrl-btns{display:flex;gap:10px}
  .btn{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;padding:13px 22px;cursor:pointer;border-radius:0;transition:all .25s;border:1px solid var(--gold);background:var(--gold);color:var(--bg);font-weight:500}
  .btn:hover{background:var(--bone);border-color:var(--bone);letter-spacing:.18em}
  .btn:disabled{opacity:.5;cursor:default}
  .btn.ghost{background:transparent;color:var(--mute);border-color:var(--border)}
  .btn.ghost:hover{color:var(--gold);border-color:var(--gold);background:transparent;letter-spacing:.14em}

  .narration{min-height:24px;margin:18px 0 6px;font-family:var(--mono);font-size:12px;letter-spacing:.04em;color:var(--mute);display:flex;align-items:center;gap:10px;transition:color .3s}
  .narration.active{color:var(--gold)}
  .narration .nd{width:7px;height:7px;border-radius:50%;background:var(--border);transition:all .3s}
  .narration.active .nd{background:var(--gold);box-shadow:0 0 10px var(--gold)}

  .canvas-scroll{overflow-x:auto;overflow-y:hidden;margin:8px -28px 0;padding:24px 28px 40px}
  .canvas{position:relative;min-width:1080px;display:grid;grid-template-columns:1fr 1.15fr 1fr;gap:64px;align-items:stretch}
  .col{display:flex;flex-direction:column;justify-content:center;gap:14px;position:static}
  .col-title{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--mute);margin-bottom:4px;display:flex;align-items:center;gap:10px}
  .col-title .ci{width:18px;height:1px;background:var(--gold-soft)}
  .col-sub{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--mute-2);margin:14px 0 2px}
  svg.links{position:absolute;inset:0;width:100%;height:100%;z-index:1;overflow:visible}
  svg.links path.deco{pointer-events:none}
  svg.links path.hit{pointer-events:stroke;cursor:help}
  .col,.node{z-index:2;position:relative}
  .node.stream-end{border-color:var(--gold)!important;box-shadow:0 0 0 1px var(--gold-glow)}

  /* stream tooltip */
  .stip{position:fixed;z-index:300;pointer-events:none;opacity:0;transform:translateY(6px);transition:opacity .16s,transform .16s;background:var(--surface-2);border:1px solid var(--gold-soft);border-left:2px solid var(--gold);padding:13px 16px;max-width:300px;box-shadow:0 16px 44px rgba(0,0,0,.5)}
  .stip.show{opacity:1;transform:translateY(0)}
  .stip-head{font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--mute);margin-bottom:9px;display:flex;align-items:center;gap:7px}
  .stip-head b{color:var(--bone)}
  .stip-arrow{color:var(--gold)}
  .stip-carry{font-family:var(--mono);font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:5px}
  .stip-payload{font-family:var(--serif);font-size:15px;color:var(--bone);line-height:1.3;margin-bottom:10px}
  .stip-payload em{color:var(--gold);font-style:italic;font-weight:300}
  .stip-cadence{font-family:var(--mono);font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--mute);display:flex;align-items:center;gap:7px;border-top:1px solid var(--border-soft);padding-top:9px}
  .stip-dot{width:6px;height:6px;border-radius:50%}
  .cad-weekly{background:var(--gold)} .cad-continuous{background:var(--moss)} .cad-quarterly{background:var(--burnt)} .cad-annual{background:var(--teal)} .cad-signing{background:var(--bone-2)}

  .node{background:var(--surface);border:1px solid var(--border);padding:14px 16px;cursor:pointer;transition:border-color .25s,background .25s,box-shadow .35s,transform .25s;border-left:2px solid var(--border)}
  .node:hover{border-color:var(--gold-soft);background:var(--surface-2);transform:translateY(-1px)}
  .node:hover .node-cta{opacity:1}
  .node.sel{border-color:var(--gold);box-shadow:0 0 0 1px var(--gold-glow)}
  .node.tap{border-left-color:var(--gold)}.node.crawl{border-left-color:var(--teal)}.node.engine{border-left-color:var(--bone-2)}.node.artifact{border-left-color:var(--burnt)}
  .node.engine{animation:breatheNode 4.5s ease-in-out infinite}
  @keyframes breatheNode{0%,100%{box-shadow:0 0 0 0 rgba(201,164,76,0)}50%{box-shadow:0 0 14px 0 rgba(201,164,76,.06)}}
  .node.pulse{box-shadow:0 0 0 3px var(--gold-glow),0 8px 30px rgba(201,164,76,.15)!important;border-color:var(--gold);background:var(--surface-2);transform:translateY(-1px);animation:none}
  .node.materialize{animation:mat .9s cubic-bezier(.2,.7,.3,1)}
  @keyframes mat{0%{box-shadow:0 0 0 0 var(--gold)}30%{box-shadow:0 0 0 8px rgba(201,164,76,.35)}100%{box-shadow:0 0 0 1px var(--gold-glow)}}
  .node-title{font-family:var(--serif);font-size:16px;color:var(--bone);letter-spacing:-.01em;line-height:1.15}
  .node-sub{font-family:var(--mono);font-size:9.5px;letter-spacing:.05em;text-transform:uppercase;color:var(--mute);margin-top:5px}
  .node.engine .node-title{font-size:15px}
  .node-cta{font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);margin-top:9px;opacity:.55;transition:opacity .25s}
  .node-badge{position:absolute;top:-9px;right:10px;font-family:var(--mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;background:var(--gold);color:var(--bg);padding:3px 7px;opacity:0;transition:opacity .4s}
  .node.bound .node-badge{opacity:1}

  footer{padding:40px 28px 56px;text-align:center;font-family:var(--mono);font-size:10px;color:var(--mute-2);letter-spacing:.12em;text-transform:uppercase}
  footer span{color:var(--gold)}

  /* MODAL */
  .modal-bd{position:fixed;inset:0;background:rgba(8,10,18,.92);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:200;display:none;align-items:center;justify-content:center;padding:24px;opacity:0;transition:opacity .25s}
  .modal-bd.open{display:flex;opacity:1}
  .modal{background:var(--surface);border:1px solid var(--border);max-width:720px;width:100%;max-height:90vh;display:flex;flex-direction:column;position:relative;box-shadow:0 30px 80px rgba(0,0,0,.55);transform:translateY(18px);transition:transform .35s cubic-bezier(.2,.7,.3,1)}
  .modal-bd.open .modal{transform:translateY(0)}
  .modal-top{padding:26px 32px 20px;flex-shrink:0;border-bottom:1px solid var(--border-soft)}
  .modal-step{display:flex;align-items:center;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--mute);margin-bottom:16px}
  .modal-step .stage-pill{padding:4px 10px;border:1px solid;border-radius:1px}
  .stage-pill.tap{color:var(--gold);border-color:var(--gold-soft)}.stage-pill.crawl{color:var(--teal);border-color:var(--teal)}.stage-pill.engine{color:var(--bone-2);border-color:var(--mute-2)}.stage-pill.artifact{color:var(--burnt);border-color:var(--burnt)}
  .modal-title{font-family:var(--serif);font-size:27px;color:var(--bone);letter-spacing:-.02em;line-height:1.12;margin-bottom:8px}
  .modal-plain{font-size:14.5px;color:var(--bone-2);line-height:1.55}
  .modal-plain b{color:var(--gold);font-weight:500}
  .modal-body{padding:22px 32px;overflow-y:auto;flex:1}

  .dash-kpis{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--border);margin-bottom:16px}
  .kpi{padding:14px 16px;border-right:1px solid var(--border-soft)}
  .kpi:last-child{border-right:none}
  .kpi-v{font-family:var(--serif);font-size:24px;color:var(--gold);line-height:1}
  .kpi-l{font-family:var(--mono);font-size:8.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--mute);margin-top:8px;display:flex;align-items:center;gap:5px}
  .kpi-t{font-size:8px}.kpi-t.up{color:var(--moss)}.kpi-t.down{color:var(--burnt)}.kpi-t.flat{color:var(--mute-2)}

  .dash-signal{display:flex;align-items:center;gap:11px;font-family:var(--serif);font-style:italic;font-size:15px;color:var(--bone);padding:13px 16px;background:var(--bg-2);border-left:2px solid var(--gold);margin-bottom:20px;line-height:1.4}
  .sig-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);box-shadow:0 0 8px var(--gold);flex-shrink:0;animation:breathe 2s ease-in-out infinite}
  @keyframes breathe{0%,100%{opacity:.45}50%{opacity:1}}

  .art-caption{font-family:var(--mono);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--mute);margin-bottom:14px;display:flex;align-items:center;gap:8px}
  .art-caption::before{content:'';width:14px;height:1px;background:var(--gold-soft)}
  .dash-visual{margin-bottom:6px}

  .dsupport-head{font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin:24px 0 12px;display:flex;align-items:center;gap:8px}
  .dsupport-head::before{content:'';width:14px;height:1px;background:var(--gold-soft)}
  .dsupport{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
  .dcard{border:1px solid var(--border);border-top:2px solid var(--border);padding:14px;cursor:pointer;transition:transform .2s,border-color .2s,box-shadow .2s,background .2s;background:var(--surface-2);display:flex;flex-direction:column}
  .dcard:hover{transform:translateY(-2px);border-color:var(--gold-soft)}
  .dcard.rec{border-top-color:var(--gold)}
  .dcard.chosen{border-color:var(--gold);box-shadow:0 0 0 1px var(--gold-glow);background:rgba(201,164,76,.05)}
  .dc-k{font-family:var(--mono);font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--mute);margin-bottom:8px;display:flex;align-items:center;gap:5px}
  .dcard.rec .dc-k{color:var(--gold)}
  .dc-k .star{color:var(--gold)}
  .dc-a{font-family:var(--serif);font-size:15px;color:var(--bone);line-height:1.18;margin-bottom:8px}
  .dc-why{font-size:11.5px;color:var(--mute);line-height:1.4;margin-bottom:12px;flex:1}
  .dc-foot{border-top:1px solid var(--border-soft);padding-top:10px;display:flex;flex-direction:column;gap:7px}
  .dc-imp{font-family:var(--mono);font-size:11px;color:var(--gold)}
  .dc-c{display:flex;align-items:center;gap:7px;font-family:var(--mono);font-size:9px;color:var(--mute)}
  .cf{flex:1;height:3px;background:var(--border)}
  .cfill{height:100%;background:var(--gold-soft);width:0;transition:width .85s cubic-bezier(.2,.7,.3,1)}
  .dsupport-out{font-family:var(--mono);font-size:11px;color:var(--bone-2);margin-top:14px;padding:13px 16px;background:var(--bg-2);border:1px dashed var(--gold-soft);letter-spacing:.02em;line-height:1.5}
  .dsupport-out b{color:var(--gold)}

  .modal-why{margin:0 32px;padding:18px 0 4px;border-top:1px solid var(--border-soft)}
  .modal-why-label{font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:8px}
  .modal-why-text{font-size:14px;color:var(--bone-2);line-height:1.55}
  .modal-nav{display:flex;align-items:center;justify-content:space-between;padding:18px 32px 24px;flex-shrink:0;gap:12px}
  .nav-mini{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:11px 18px;cursor:pointer;background:transparent;border:1px solid var(--border);color:var(--bone-2);transition:all .2s}
  .nav-mini:hover:not(:disabled){border-color:var(--gold);color:var(--gold)}
  .nav-mini:disabled{opacity:.35;cursor:default}
  .nav-next{background:var(--gold);border-color:var(--gold);color:var(--bg);font-weight:500}
  .nav-next:hover{background:var(--bone);border-color:var(--bone);color:var(--bg)}
  .modal-close{position:absolute;top:18px;right:18px;width:30px;height:30px;border:1px solid var(--border);background:transparent;color:var(--mute);font-size:16px;cursor:pointer;line-height:1;transition:all .2s;z-index:3}
  .modal-close:hover{color:var(--gold);border-color:var(--gold)}

  /* artifact kit */
  .art-table{width:100%;border-collapse:collapse;font-size:12.5px}
  .art-table th{font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--mute);text-align:left;padding:8px 10px;border-bottom:1px solid var(--border)}
  .art-table td{padding:9px 10px;border-bottom:1px solid var(--border-soft);color:var(--bone-2)}
  .art-table td.num{font-family:var(--mono);text-align:right;color:var(--bone)}
  .pill{display:inline-block;font-family:var(--mono);font-size:9px;letter-spacing:.06em;text-transform:uppercase;padding:2px 7px;border-radius:1px}
  .pill.green{color:var(--moss);background:rgba(107,142,90,.14)}.pill.amber{color:var(--burnt);background:rgba(201,122,58,.14)}.pill.red{color:#c96a6a;background:rgba(201,106,106,.14)}
  .contrast{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:4px}
  .c-box{border:1px solid var(--border);padding:18px}.c-box.stated{border-left:2px solid var(--mute)}.c-box.revealed{border-left:2px solid var(--gold)}
  .c-label{font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--mute);margin-bottom:10px}
  .c-text{font-family:var(--serif);font-size:15px;color:var(--bone);line-height:1.4}.c-box.revealed .c-text{color:var(--gold)}
  .bars{display:flex;flex-direction:column;gap:11px}
  .bar-row{display:grid;grid-template-columns:130px 1fr 38px;gap:14px;align-items:center}
  .bar-l{font-family:var(--serif);font-size:13px;color:var(--bone-2)}
  .track{height:6px;background:var(--border);position:relative}
  .fill{height:100%;background:var(--gold);width:0;transition:width .85s cubic-bezier(.2,.7,.3,1)}
  .fill.low{background:var(--burnt)}.fill.ok{background:var(--moss)}
  .bar-v{font-family:var(--mono);font-size:12px;color:var(--bone);text-align:right}
  .decision-card{border:1px solid var(--border);border-top:2px solid var(--oxblood);padding:22px}
  .dc-tag{font-family:var(--mono);font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--oxblood);margin-bottom:8px}
  .dc-name{font-family:var(--serif);font-size:24px;color:var(--bone);letter-spacing:-.02em;margin-bottom:14px}
  .dc-name em{color:var(--gold);font-style:italic;font-weight:300}
  .dcg{display:flex;border-top:1px solid var(--border-soft);border-bottom:1px solid var(--border-soft);margin:14px 0}
  .dcg .cell{flex:1;padding:14px 0;border-right:1px solid var(--border-soft)}.dcg .cell:last-child{border-right:none}
  .dcg .v{font-family:var(--serif);font-size:20px;color:var(--gold)}.dcg .l{font-family:var(--mono);font-size:8.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--mute);margin-top:5px}
  .dc-rec2{font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--mute);margin-top:6px}
  .ver-row{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:11px;padding:8px 0;border-bottom:1px solid var(--border-soft)}.ver-row:last-child{border-bottom:none}
  .ver-tag{color:var(--mute)}.ver-now{color:var(--gold)}.ver-arrow{color:var(--mute-2)}.ver-change{color:var(--bone-2);font-family:var(--sans);font-size:12px}
  .dim-chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:14px}
  .dim-chip{font-family:var(--mono);font-size:10px;padding:6px 10px;border:1px solid var(--border);color:var(--bone-2)}.dim-chip b{color:var(--gold);margin-left:6px}
  .before-after{display:grid;grid-template-columns:1fr auto 1fr;gap:14px;align-items:center}
  .ba-box{border:1px solid var(--border);padding:14px}.ba-box.after{border-left:2px solid var(--gold)}
  .ba-label{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--mute);margin-bottom:9px}
  .ba-line{font-family:var(--mono);font-size:11px;color:var(--bone-2);line-height:1.7}.ba-arrow{font-size:20px;color:var(--gold)}
  .agent-card{border-left:2px solid var(--gold);background:var(--bg-2);padding:13px 16px;margin-bottom:10px}
  .agent-card .ac-name{font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--gold);margin-bottom:5px}
  .agent-card .ac-find{font-size:13px;color:var(--bone-2);line-height:1.45}
  .stat-row{display:flex;border:1px solid var(--border);margin-bottom:16px}
  .stat-row .stat{flex:1;padding:14px 16px;border-right:1px solid var(--border-soft)}.stat-row .stat:last-child{border-right:none}
  .stat-row .stat-v{font-family:var(--serif);font-size:22px;color:var(--gold)}.stat-row .stat-l{font-family:var(--mono);font-size:8.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--mute);margin-top:6px}
  .paper{background:var(--paper);color:var(--paper-ink);padding:30px 32px;font-family:var(--serif);position:relative}
  .paper::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--gold),var(--oxblood))}
  .p-kicker{font-family:var(--mono);font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--paper-soft);margin-bottom:14px}
  .p-title{font-family:var(--serif);font-size:26px;color:#1a1610;letter-spacing:-.02em;line-height:1.12;margin-bottom:6px}
  .p-titles{font-style:italic;color:var(--paper-soft);font-size:15px;margin-bottom:20px}
  .p-rule{height:1px;background:var(--paper-line);margin:18px 0}
  .p-toc{list-style:none;padding:0;margin:0}
