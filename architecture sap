/* ============ BUILD CANVAS ============ */
const canvas=document.getElementById('canvas'),svg=document.getElementById('links'),elById={};
function nodeEl(id){const n=NODES[id],d=document.createElement('div');d.className='node '+n.type;d.dataset.id=id;
  d.innerHTML=`<div class="node-badge">Bound</div><div class="node-title">${n.title}</div><div class="node-sub">${SUB[id]}</div><div class="node-cta">Open dashboard →</div>`;
  d.addEventListener('click',()=>openArtifact(id));elById[id]=d;return d;}
LAYOUT.taps.forEach(id=>document.getElementById('grp-taps').appendChild(nodeEl(id)));
LAYOUT.crawl.forEach(id=>document.getElementById('grp-crawl').appendChild(nodeEl(id)));
LAYOUT.engine.forEach(id=>document.getElementById('grp-engine').appendChild(nodeEl(id)));
LAYOUT.artifacts.forEach(id=>document.getElementById('grp-artifacts').appendChild(nodeEl(id)));
['grp-taps','grp-crawl','grp-engine','grp-artifacts'].forEach(g=>{const e=document.getElementById(g);e.style.display='flex';e.style.flexDirection='column';e.style.gap='12px';});

/* ============ CONNECTORS ============ */
const KIND_COLOR={in:'var(--gold-soft)',chain:'var(--bone-2)',out:'var(--burnt)',feedback:'var(--oxblood)'};
const pathRefs=[];
function anchor(el,s){const x=el.offsetLeft,y=el.offsetTop,w=el.offsetWidth,h=el.offsetHeight;if(s==='r')return[x+w,y+h/2];if(s==='l')return[x,y+h/2];if(s==='t')return[x+w/2,y];return[x+w/2,y+h];}
function buildPath(f,t,k){const a=elById[f],b=elById[t];if(!a||!b)return'';let p1,p2,c1,c2;if(k==='chain'){p1=anchor(a,'b');p2=anchor(b,'t');const dy=Math.max(24,(p2[1]-p1[1])/2);c1=[p1[0],p1[1]+dy];c2=[p2[0],p2[1]-dy];}else if(k==='feedback'){p1=anchor(a,'l');p2=anchor(b,'l');const mx=Math.min(p1[0],p2[0])-90;c1=[mx,p1[1]];c2=[mx,p2[1]];}else{p1=anchor(a,'r');p2=anchor(b,'l');const dx=Math.max(50,(p2[0]-p1[0])/2);c1=[p1[0]+dx,p1[1]];c2=[p2[0]-dx,p2[1]];}return `M${p1[0]},${p1[1]} C${c1[0]},${c1[1]} ${c2[0]},${c2[1]} ${p2[0]},${p2[1]}`;}
function drawLinks(){svg.innerHTML='';pathRefs.length=0;const W=canvas.scrollWidth,H=canvas.scrollHeight;svg.setAttribute('width',W);svg.setAttribute('height',H);svg.setAttribute('viewBox',`0 0 ${W} ${H}`);
  // arrowhead markers (one per kind colour)
  const defs=document.createElementNS('http://www.w3.org/2000/svg','defs');
  Object.entries(KIND_COLOR).forEach(([k,col])=>{
    const mk=document.createElementNS('http://www.w3.org/2000/svg','marker');
    mk.setAttribute('id','ar-'+k);mk.setAttribute('markerWidth','7');mk.setAttribute('markerHeight','7');mk.setAttribute('refX','5.5');mk.setAttribute('refY','3');mk.setAttribute('orient','auto');mk.setAttribute('markerUnits','userSpaceOnUse');
    const tri=document.createElementNS('http://www.w3.org/2000/svg','path');tri.setAttribute('d','M0,0 L6,3 L0,6 Z');tri.setAttribute('fill',col);tri.setAttribute('opacity','0.65');
    mk.appendChild(tri);defs.appendChild(mk);
  });
  svg.appendChild(defs);
  CONNECTIONS.forEach(([f,t,k],i)=>{const d=buildPath(f,t,k);if(!d)return;const col=KIND_COLOR[k];
    const base=document.createElementNS('http://www.w3.org/2000/svg','path');base.setAttribute('class','deco');base.setAttribute('d',d);base.setAttribute('fill','none');base.setAttribute('stroke',col);base.setAttribute('stroke-width','1');base.setAttribute('opacity',k==='feedback'?'0.5':'0.32');if(k==='feedback')base.setAttribute('stroke-dasharray','4,4');base.setAttribute('marker-end','url(#ar-'+k+')');svg.appendChild(base);
    const flow=document.createElementNS('http://www.w3.org/2000/svg','path');flow.setAttribute('class','deco');flow.setAttribute('d',d);flow.setAttribute('fill','none');flow.setAttribute('stroke',col);flow.setAttribute('stroke-width','1.6');flow.setAttribute('stroke-dasharray','2,12');flow.setAttribute('stroke-linecap','round');flow.setAttribute('opacity','0.9');flow.style.animation=`flow ${k==='feedback'?6:3.2}s linear infinite`;flow.style.animationDelay=(-(i%5)*0.5)+'s';svg.appendChild(flow);
    // invisible wide hit-path for hover
    const hit=document.createElementNS('http://www.w3.org/2000/svg','path');hit.setAttribute('class','hit');hit.setAttribute('d',d);hit.setAttribute('fill','none');hit.setAttribute('stroke','transparent');hit.setAttribute('stroke-width','16');svg.appendChild(hit);
    const ref={from:f,to:t,kind:k,base,flow,hit};
    hit.addEventListener('mouseenter',()=>streamEnter(ref));
    hit.addEventListener('mousemove',moveTip);
    hit.addEventListener('mouseleave',streamLeave);
    pathRefs.push(ref);});}
const styleEl=document.createElement('style');styleEl.textContent='@keyframes flow{from{stroke-dashoffset:140}to{stroke-dashoffset:0}}';document.head.appendChild(styleEl);
function highlightConnections(id){pathRefs.forEach(p=>{const on=(p.from===id||p.to===id);p.flow.setAttribute('opacity',on?'1':'0.18');p.base.setAttribute('opacity',on?'0.7':'0.12');p.flow.setAttribute('stroke-width',on?'2.2':'1.2');});}
function clearHighlight(){pathRefs.forEach(p=>{p.flow.setAttribute('opacity','0.9');p.flow.setAttribute('stroke-width','1.6');p.base.setAttribute('opacity',p.kind==='feedback'?'0.5':'0.32');});}

/* ============ STREAM HOVER ============ */
const stip=document.getElementById('stip');
function streamEnter(ref){
  if(modal.classList.contains('open'))return;
  const s=STREAM[ref.from+'>'+ref.to];if(!s)return;
  pathRefs.forEach(p=>{const on=p===ref;p.flow.setAttribute('opacity',on?'1':'0.14');p.flow.setAttribute('stroke-width',on?'2.8':'1.1');p.base.setAttribute('opacity',on?'0.85':'0.1');});
  [ref.from,ref.to].forEach(id=>elById[id]&&elById[id].classList.add('stream-end'));
  document.getElementById('stip-from').textContent=NODES[ref.from].title;
  document.getElementById('stip-to').textContent=NODES[ref.to].title;
  document.getElementById('stip-payload').innerHTML=s.p;
  document.getElementById('stip-cadence').textContent=CAD_LABEL[s.c];
  document.getElementById('stip-dot').className='stip-dot cad-'+s.c;
  stip.classList.add('show');
}
function moveTip(e){
  const pad=16,w=stip.offsetWidth||280,h=stip.offsetHeight||120;
  let x=e.clientX+pad,y=e.clientY+pad;
  if(x+w>window.innerWidth-8)x=e.clientX-w-pad;
  if(y+h>window.innerHeight-8)y=e.clientY-h-pad;
  stip.style.left=x+'px';stip.style.top=y+'px';
}
function streamLeave(){stip.classList.remove('show');clearHighlight();Object.values(elById).forEach(e=>e.classList.remove('stream-end'));}

/* ============ MODAL RENDER (harmonized dashboard) ============ */
const modal=document.getElementById('modal-bd'),mBody=document.getElementById('m-body');
const TYPE_LABEL={tap:'System of record',crawl:'External crawl',engine:'Engine stage',artifact:'Artifact'};
let currentId=null;

function deck(decs){
  const cards=decs.map((d,i)=>`<div class="dcard ${d.r?'rec':''} ${d.r?'chosen':''}" data-i="${i}" data-a="${d.a}" data-imp="${d.imp}"><div class="dc-k">${d.r?'<span class="star">★</span> Recommended':'Alternative'}</div><div class="dc-a">${d.a}</div><div class="dc-why">${d.w}</div><div class="dc-foot"><span class="dc-imp">${d.imp}</span><span class="dc-c"><span class="cf"><span class="cfill" data-w="${Math.round(d.c*100)}"></span></span>${d.c.toFixed(2)}</span></div></div>`).join('');
  const rec=decs.find(d=>d.r)||decs[0];
  return `<div class="dsupport-head">Decision support · choose a path</div><div class="dsupport">${cards}</div><div class="dsupport-out" id="dsupport-out">Selected path → <b>${rec.a}</b> · ${rec.imp}</div>`;
}
function kpiStrip(kpis){return `<div class="dash-kpis">${kpis.map(k=>`<div class="kpi"><div class="kpi-v" data-count="${k.v}">${k.v}</div><div class="kpi-l">${k.l}${k.t?` <span class="kpi-t ${k.t}">${k.t==='up'?'▲':k.t==='down'?'▼':'—'}</span>`:''}</div></div>`).join('')}</div>`;}

function openArtifact(id){
  currentId=id;const n=NODES[id],a=ART[id],idx=ORDER.indexOf(id);
  Object.values(elById).forEach(e=>e.classList.remove('sel'));elById[id].classList.add('sel');highlightConnections(id);
  const pill=document.getElementById('m-pill');pill.className='stage-pill '+n.type;pill.textContent=TYPE_LABEL[n.type];
  document.getElementById('m-step').textContent=`Step ${idx+1} of ${ORDER.length}`;
  document.getElementById('m-title').textContent=n.title;
  document.getElementById('m-plain').innerHTML=a.plain;
  document.getElementById('m-why').textContent=a.why;
  document.getElementById('m-prev').disabled=(idx===0);
  document.getElementById('m-next').textContent=(idx===ORDER.length-1)?'Done ✓':'Next stage →';
  mBody.innerHTML = kpiStrip(a.kpis)
    + `<div class="dash-signal"><span class="sig-dot"></span>${a.signal}</div>`
    + `<div class="art-caption">${a.cap}</div>`
    + `<div class="dash-visual">${a.html}</div>`
    + deck(a.dec);
  wireDeck();
  modal.classList.add('open');document.body.style.overflow='hidden';mBody.scrollTop=0;
  requestAnimationFrame(()=>{animateCounts();animateBars();});
}
function wireDeck(){
  const out=document.getElementById('dsupport-out');
  mBody.querySelectorAll('.dcard').forEach(card=>{
    card.addEventListener('click',()=>{
      mBody.querySelectorAll('.dcard').forEach(c=>c.classList.remove('chosen'));
      card.classList.add('chosen');
      out.innerHTML=`Selected path → <b>${card.dataset.a}</b> · ${card.dataset.imp}`;
    });
  });
}
function animateCounts(){
  mBody.querySelectorAll('[data-count]').forEach(el=>{
    const raw=el.dataset.count;const m=raw.match(/^([^\d\-]*)(-?[\d.]+)(.*)$/);
    if(!m){el.textContent=raw;return;}
    const pre=m[1],num=parseFloat(m[2]),suf=m[3],dec=(m[2].split('.')[1]||'').length;
    const dur=850,t0=performance.now();
    function tick(now){const t=Math.min(1,(now-t0)/dur),e=1-Math.pow(1-t,3),v=num*e;el.textContent=pre+(dec?v.toFixed(dec):Math.round(v))+suf;if(t<1)requestAnimationFrame(tick);else el.textContent=raw;}
    requestAnimationFrame(tick);
  });
}
function animateBars(){
  mBody.querySelectorAll('.fill').forEach(f=>{const w=f.style.width;f.style.width='0';requestAnimationFrame(()=>requestAnimationFrame(()=>{f.style.width=w;}));});
  mBody.querySelectorAll('.cfill').forEach(f=>{const w=f.dataset.w+'%';f.style.width='0';requestAnimationFrame(()=>requestAnimationFrame(()=>{f.style.width=w;}));});
}
function step(dir){const idx=ORDER.indexOf(currentId)+dir;if(idx<0)return;if(idx>=ORDER.length){closeModal();return;}openArtifact(ORDER[idx]);}
function closeModal(){modal.classList.remove('open');document.body.style.overflow='';clearHighlight();Object.values(elById).forEach(e=>e.classList.remove('sel'));}
document.getElementById('m-prev').addEventListener('click',()=>step(-1));
document.getElementById('m-next').addEventListener('click',()=>step(1));
document.getElementById('modal-close').addEventListener('click',closeModal);
modal.addEventListener('click',e=>{if(e.target===modal)closeModal();});
document.addEventListener('keydown',e=>{if(!modal.classList.contains('open'))return;if(e.key==='Escape')closeModal();if(e.key==='ArrowRight')step(1);if(e.key==='ArrowLeft')step(-1);});
document.getElementById('tour-btn').addEventListener('click',()=>openArtifact(ORDER[0]));

/* ============ RUN PIPELINE ============ */
const narration=document.getElementById('narration'),narrationTxt=document.getElementById('narration-txt');let running=false;
const SEQUENCE=[{ids:['sap','planview','anaplan','workday','dwh'],txt:'Pulling portfolio, spend & planning telemetry from the systems of record\u2026'},{ids:['filings','analyst','patents','peers'],txt:'Crawling filings, analyst coverage, patents and the peer cohort\u2026'},{ids:['ingest'],txt:'Normalizing every source into one schema \u2014 weekly cadence\u2026'},{ids:['store'],txt:'Writing the versioned genotype into the persistent store\u2026'},{ids:['graph'],txt:'Rendering the company as a scored semantic graph\u2026'},{ids:['agents'],txt:'14 agents reasoning \u2014 each leaving a finding in the trail\u2026'},{ids:['scoring'],txt:'Scoring six dimensions with confidence intervals\u2026'},{ids:['phenotype'],txt:'Generating the decision \u2014 CONSOLIDATE, €60M Year-1, 3 alternatives weighed\u2026'},{ids:['briefing'],txt:'Binding the Q3 Board Briefing Pack \u2014 shipped to each board member.',bind:true}];
function clearPulse(){Object.values(elById).forEach(e=>e.classList.remove('pulse'));}
function runPipeline(){if(running)return;running=true;resetView(false);narration.classList.add('active');document.getElementById('run-btn').disabled=true;let s=0;
  (function next(){if(s>0)SEQUENCE[s-1].ids.forEach(id=>elById[id].classList.remove('pulse'));
   if(s>=SEQUENCE.length){narrationTxt.textContent='Done. Opening the Board Briefing that was just generated\u2026';elById['briefing'].classList.add('bound');running=false;document.getElementById('run-btn').disabled=false;setTimeout(()=>{openArtifact('briefing');narration.classList.remove('active');},700);return;}
   const st=SEQUENCE[s];narrationTxt.textContent=st.txt;st.ids.forEach(id=>elById[id].classList.add('pulse'));if(st.ids.length===1)highlightConnections(st.ids[0]);else clearHighlight();if(st.bind)elById['briefing'].classList.add('materialize');s++;setTimeout(next,st.ids.length>1?1100:950);})();}
function resetView(full=true){clearPulse();clearHighlight();Object.values(elById).forEach(e=>e.classList.remove('sel','bound','materialize'));if(full){narrationTxt.textContent='Click any box for its dashboard & decision support — or run the pipeline to generate a Board Briefing.';narration.classList.remove('active');}}
document.getElementById('run-btn').addEventListener('click',runPipeline);
document.getElementById('reset-btn').addEventListener('click',()=>{if(!running)resetView(true);});

function init(){drawLinks();}
window.addEventListener('load',()=>requestAnimationFrame(init));
let rt;window.addEventListener('resize',()=>{clearTimeout(rt);rt=setTimeout(drawLinks,180);});
requestAnimationFrame(init);
</script>
