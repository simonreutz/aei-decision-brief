<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Genotwin Cockpit · AEI on AEI</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  /* ---------- tokens ---------- */
  :root {
    --bg: #0c0e1a;
    --bg-2: #11142a;
    --surface: #151829;
    --surface-2: #1a1e34;
    --border: #252a44;
    --border-soft: #1d2138;
    --gold: #c9a44c;
    --gold-soft: #8a7333;
    --gold-glow: rgba(201,164,76,.18);
    --oxblood: #7a2e2e;
    --oxblood-soft: #5a2222;
    --burnt: #c97a3a;
    --moss: #6b8e5a;
    --bone: #e8e3d5;
    --bone-2: #c8c2b1;
    --mute: #7a8099;
    --mute-2: #565b76;
    --serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
  }

  /* ---------- reset / base ---------- */
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--bone);
    font-family: var(--sans);
    font-weight: 400;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }
  ::selection { background: var(--gold); color: var(--bg); }

  /* ---------- ambient background texture ---------- */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(201,164,76,.06), transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(122,46,46,.05), transparent 60%);
    z-index: 0;
  }

  /* ---------- nav ---------- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(12,14,26,.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-soft);
  }
  .nav-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .brand {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--bone);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .brand-mark {
    width: 22px; height: 22px;
    border: 1.5px solid var(--gold);
    border-radius: 50%;
    position: relative;
    display: inline-block;
  }
  .brand-mark::after {
    content: '';
    position: absolute;
    inset: 4px;
    background: var(--gold);
    border-radius: 50%;
    opacity: 0.7;
  }
  .brand-meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-left: 14px;
    padding-left: 14px;
    border-left: 1px solid var(--border);
  }
  .nav-links {
    display: flex;
    gap: 28px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--gold); }

  /* ---------- containers ---------- */
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 32px; position: relative; z-index: 1; }
  .wrap-narrow { max-width: 880px; margin: 0 auto; padding: 0 32px; position: relative; z-index: 1; }

  section { padding: 110px 0; position: relative; }
  section + section { border-top: 1px solid var(--border-soft); }

  /* ---------- eyebrow / section heading ---------- */
  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }
  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: var(--gold);
  }
  h1, h2, h3 { font-family: var(--serif); font-weight: 400; margin: 0; letter-spacing: -0.02em; }
  h1 { font-size: clamp(40px, 6vw, 72px); line-height: 1.04; }
  h2 { font-size: clamp(32px, 4.4vw, 50px); line-height: 1.08; }
  h3 { font-size: 22px; line-height: 1.25; }
  p { color: var(--bone-2); font-size: 16px; }

  /* ---------- HERO ---------- */
  .hero { padding-top: 80px; padding-bottom: 60px; }
  .hero-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 56px;
  }
  .hero-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--mute);
    text-transform: uppercase;
    line-height: 1.8;
  }
  .hero-meta strong { color: var(--bone); font-weight: 500; }
  .hero h1 { max-width: 16ch; margin-bottom: 32px; }
  .hero h1 em {
    font-style: italic;
    color: var(--gold);
    font-weight: 300;
  }
  .hero-lede {
    font-family: var(--serif);
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.5;
    color: var(--bone-2);
    max-width: 64ch;
    font-weight: 300;
    margin-bottom: 64px;
  }

  /* counter row */
  .counters {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .counter {
    padding: 24px 28px;
    border-right: 1px solid var(--border-soft);
  }
  .counter:last-child { border-right: none; }
  .counter-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute);
    margin-bottom: 8px;
  }
  .counter-value {
    font-family: var(--serif);
    font-size: 34px;
    font-weight: 400;
    color: var(--bone);
    letter-spacing: -0.02em;
  }
  .counter-suffix {
    font-size: 14px;
    color: var(--mute);
    font-family: var(--sans);
    margin-left: 4px;
  }

  /* ---------- QUADRANT ---------- */
  .quadrant-wrap {
    margin-top: 80px;
    padding: 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    position: relative;
  }
  .quadrant-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 32px;
  }
  .quadrant-title {
    font-family: var(--serif);
    font-size: 20px;
    color: var(--bone);
  }
  .quadrant-sub {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ---------- AEI SCORE: Genotwin ---------- */
  .score-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 56px;
    align-items: start;
    margin-top: 56px;
  }
  .score-panel {
    padding: 36px;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .score-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 8px;
  }
  .score-record {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .score-value-row {
    display: flex; align-items: baseline; gap: 16px;
    margin: 18px 0 6px;
  }
  .score-value {
    font-family: var(--serif);
    font-size: 84px;
    font-weight: 300;
    color: var(--bone);
    letter-spacing: -0.03em;
    line-height: 0.9;
  }
  .score-band {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--burnt);
    letter-spacing: 0.06em;
  }
  .score-band-label { color: var(--mute); margin-right: 8px; }
  .score-context {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--bone-2);
    margin-top: 10px;
    margin-bottom: 36px;
    max-width: 50ch;
    line-height: 1.5;
  }

  /* sequence strip — the signature element */
  .sequence-strip {
    margin-top: 24px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }
  .sequence-strip-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
  }

  /* dimension list (right panel) */
  .dims {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .dims li {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border-soft);
    align-items: center;
  }
  .dims li:last-child { border-bottom: none; }
  .dim-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--mute);
  }
  .dim-name {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--bone);
  }
  .dim-name small {
    display: block;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--mute);
    margin-top: 3px;
    line-height: 1.4;
  }
  .dim-score {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--gold);
  }
  .dim-score.low { color: var(--burnt); }
  .dim-score.ok { color: var(--moss); }

  /* phenotypes */
  .phenotypes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 64px;
  }
  .pheno {
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 2px solid var(--oxblood);
    position: relative;
    transition: transform .25s ease, border-color .25s ease;
  }
  .pheno:hover {
    transform: translateY(-2px);
    border-top-color: var(--gold);
  }
  .pheno-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--oxblood);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .pheno-name {
    font-family: var(--serif);
    font-size: 26px;
    color: var(--bone);
    letter-spacing: -0.02em;
    margin-bottom: 14px;
  }
  .pheno-name em {
    color: var(--gold);
    font-style: italic;
    font-weight: 300;
  }
  .pheno-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--bone-2);
    margin-bottom: 16px;
  }
  .pheno-meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-top: 1px solid var(--border-soft);
    padding-top: 14px;
  }

  /* blind spots */
  .blindspots {
    margin-top: 64px;
  }
  .blindspots h3 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--mute);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 24px;
  }
  .bs-row {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 24px;
    padding: 22px 0;
    border-top: 1px solid var(--border-soft);
    align-items: center;
  }
  .bs-row:last-child { border-bottom: 1px solid var(--border-soft); }
  .bs-id {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--burnt);
    letter-spacing: 0.06em;
  }
  .bs-content { display: flex; flex-direction: column; gap: 4px; }
  .bs-title {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--bone);
  }
  .bs-desc {
    font-size: 13px;
    color: var(--mute);
  }
  .bs-value {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--burnt);
    text-align: right;
    white-space: nowrap;
  }

  /* ---------- THRESHOLD ---------- */
  .threshold {
    text-align: center;
    padding: 140px 0;
    background:
      linear-gradient(180deg, transparent 0%, var(--bg-2) 50%, transparent 100%);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .threshold-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .threshold h2 {
    max-width: 22ch;
    margin: 0 auto 24px;
    font-style: italic;
    font-weight: 300;
  }
  .threshold-sub {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--bone-2);
    max-width: 56ch;
    margin: 0 auto 48px;
    line-height: 1.55;
  }
  .threshold-btn {
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 18px 36px;
    cursor: pointer;
    transition: all .3s;
    border-radius: 0;
  }
  .threshold-btn:hover {
    background: var(--gold);
    color: var(--bg);
    letter-spacing: 0.22em;
  }
  .threshold-btn span { margin-left: 12px; transition: transform .3s; display: inline-block; }
  .threshold-btn:hover span { transform: translateX(6px); }

  /* ---------- CUSTOMER VIEW ---------- */
  .customer-view {
    display: none;
    background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 100%);
    padding: 110px 0;
    border-bottom: 1px solid var(--border);
  }
  .customer-view.is-open { display: block; }
  .cv-banner {
    background: var(--surface);
    border: 1px solid var(--gold-soft);
    padding: 20px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 56px;
    border-left: 3px solid var(--gold);
  }
  .cv-banner-text {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  .cv-banner-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .cv-banner-msg {
    font-family: var(--serif);
    font-size: 15px;
    color: var(--bone-2);
    font-style: italic;
  }
  .cv-close {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--mute);
    background: none;
    border: none;
    cursor: pointer;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cv-close:hover { color: var(--bone); }

  .cv-card-head {
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
    margin-bottom: 36px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .cv-customer {
    font-family: var(--serif);
    font-size: 36px;
    color: var(--bone);
    letter-spacing: -0.02em;
  }
  .cv-customer small {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--mute);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .cv-quarter {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--mute);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: right;
  }
  .cv-quarter strong { color: var(--gold); display: block; font-size: 22px; font-family: var(--serif); margin-top: 6px; letter-spacing: -0.01em; text-transform: none; }

  .cv-value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }
  .cv-vc {
    padding: 32px;
    border-right: 1px solid var(--border-soft);
  }
  .cv-vc:last-child { border-right: none; }
  .cv-vc-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .cv-vc-value {
    font-family: var(--serif);
    font-size: 38px;
    font-weight: 400;
    color: var(--gold);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 8px;
  }
  .cv-vc-context {
    font-size: 13px;
    color: var(--bone-2);
    line-height: 1.5;
  }

  /* sample decision phenotype card */
  .cv-decision {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 40px;
  }
  .cv-decision-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-soft);
  }
  .cv-decision-tag {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--oxblood);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .cv-decision-title {
    font-family: var(--serif);
    font-size: 28px;
    color: var(--bone);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .cv-decision-title em {
    color: var(--gold);
    font-style: italic;
    font-weight: 300;
  }
  .cv-decision-rec {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cv-decision-body {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.65;
    color: var(--bone-2);
    margin-bottom: 24px;
  }
  .cv-reasoning {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--border-soft);
  }
  .cv-reasoning-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .cv-agents {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .cv-agent {
    display: flex;
    gap: 14px;
    padding: 12px 0;
    align-items: flex-start;
  }
  .cv-agent-name {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gold);
    width: 90px;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }
  .cv-agent-finding {
    font-size: 13px;
    color: var(--bone-2);
    line-height: 1.5;
  }

  /* ---------- VAULT ---------- */
  .vault-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
    margin-top: 56px;
  }
  .vault-tile {
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 28px;
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: background .2s;
    cursor: default;
  }
  .vault-tile:hover { background: var(--surface); }
  .vault-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--mute);
    letter-spacing: 0.1em;
  }
  .vault-name {
    font-family: var(--serif);
    font-size: 19px;
    color: var(--bone);
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .vault-meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .vault-meta.pdf { color: var(--burnt); }
  .vault-meta.html { color: var(--moss); }

  /* ---------- MISSION (kanban) ---------- */
  .mission-board {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    position: relative;
  }
  .mission-col {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px 20px;
    min-height: 320px;
    display: flex;
    flex-direction: column;
  }
  .mission-col.is-active {
    border-color: var(--gold);
    background: linear-gradient(180deg, var(--surface) 0%, rgba(201,164,76,.04) 100%);
  }
  .mission-col.is-active::before {
    content: 'ACTIVE';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 9px;
    background: var(--gold);
    color: var(--bg);
    padding: 3px 8px;
    letter-spacing: 0.16em;
  }
